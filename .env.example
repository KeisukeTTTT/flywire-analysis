# Data path — this repository does NOT ship the FlyWire data itself.
# Each environment must point DROSOPHILA_DATA_DIR at a local copy of the
# drosophila project's `data/` directory (raw/flywire/, derived/geometry/, etc.).
# Copy this file to `.env.local` and set the absolute path for your machine.
DROSOPHILA_DATA_DIR=/absolute/path/to/drosophila/data
